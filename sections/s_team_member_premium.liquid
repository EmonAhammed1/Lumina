
{%- liquid
  assign bg_color = section.settings.bgsection | default: '#000000'
  assign text_color = '#ffffff'
  assign gold_color = '#D4AF37'
  assign card_bg = '#050505'
-%}

<div class="steam-premium__section-wrapper" id="section-{{ section.id }}" style="background-color: {{ bg_color }}; color: {{ text_color }};">
  
  <!-- HERO SECTION -->
  <div class="steam-premium__hero">
    <div class="steam-premium__container">
      <div class="steam-premium__hero-grid">
        <div class="steam-premium__hero-content" data-reveal="fade-up">
          <span class="steam-premium__hero-tag">{{ section.settings.title_top | uppercase }}</span>
          <h1 class="steam-premium__hero-title">
            Specialiștii din spatele <span class="text-gold">Lumina Europa</span>
          </h1>
          <p class="steam-premium__hero-subtitle">
            {{ section.settings.des }}
          </p>
          <div class="steam-premium__hero-divider"></div>
        </div>
        <div class="steam-premium__hero-visual">
          <canvas id="hero-particles-canvas"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- TEAM SECTION -->
  <div class="steam-premium__team-grid-section">
    <div class="steam-premium__container">
      <div class="steam-premium__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'member' -%}
            <div class="steam-member-premium__card reveal-card" {{ block.shopify_attributes }}>
              <div class="steam-member-premium__card-inner">
                
                <!-- Left Side: Portrait Image -->
                <div class="steam-member-premium__portrait">
                  <div class="steam-member-premium__image-wrapper">
                    {%- liquid
                      case forloop.index
                        when 1
                          assign fallback_img = 'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&q=80&w=600'
                        when 2
                          assign fallback_img = 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=600'
                        when 3
                          assign fallback_img = 'https://images.unsplash.com/photo-1581579438747-1dc8d1e0ca96?auto=format&fit=crop&q=80&w=600'
                        when 4
                          assign fallback_img = 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&q=80&w=600'
                        when 5
                          assign fallback_img = 'https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=600'
                        else
                          assign fallback_img = 'https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=600'
                      endcase

                      if block.settings.image != blank
                        assign img_url = block.settings.image | image_url: width: 600
                      else
                        assign img_url = fallback_img
                      endif
                    -%}
                    <img src="{{ img_url }}" 
                         alt="{{ block.settings.name }}" 
                         loading="lazy"
                         class="steam-member-premium__img"
                         onerror="this.onerror=null; this.src='{{ fallback_img }}';">
                    <div class="steam-member-premium__image-overlay"></div>
                  </div>
                </div>

                <!-- Right Side: Details -->
                <div class="steam-member-premium__info">
                  <span class="steam-member-premium__role">{{ block.settings.role | uppercase }}</span>
                  <h3 class="steam-member-premium__name">{{ block.settings.name }}</h3>
                  <p class="steam-member-premium__desc">{{ block.settings.description }}</p>
                  
                  <!-- Expertise list -->
                  <div class="steam-member-premium__expertises">
                    {%- if block.settings.exp_title_1 != blank -%}
                      <div class="steam-member-premium__exp-item">
                        <div class="steam-member-premium__exp-icon-wrap">
                          {%- if block.settings.exp_image_1 != blank -%}
                            <img src="{{ block.settings.exp_image_1 | image_url: width: 60 }}" alt="{{ block.settings.exp_title_1 }}" style="width: 18px; height: 18px; object-fit: contain; filter: brightness(0) saturate(100%) invert(84%) sepia(21%) saturate(1512%) hue-rotate(5deg) brightness(93%) contrast(85%);">
                          {%- else -%}
                            {%- render 'premium-icons', icon_name: block.settings.exp_icon_1 -%}
                          {%- endif -%}
                        </div>
                        <div class="steam-member-premium__exp-text">
                          <h4 class="steam-member-premium__exp-title">{{ block.settings.exp_title_1 }}</h4>
                          <p class="steam-member-premium__exp-desc">{{ block.settings.exp_desc_1 }}</p>
                        </div>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.exp_title_2 != blank -%}
                      <div class="steam-member-premium__exp-item">
                        <div class="steam-member-premium__exp-icon-wrap">
                          {%- if block.settings.exp_image_2 != blank -%}
                            <img src="{{ block.settings.exp_image_2 | image_url: width: 60 }}" alt="{{ block.settings.exp_title_2 }}" style="width: 18px; height: 18px; object-fit: contain; filter: brightness(0) saturate(100%) invert(84%) sepia(21%) saturate(1512%) hue-rotate(5deg) brightness(93%) contrast(85%);">
                          {%- else -%}
                            {%- render 'premium-icons', icon_name: block.settings.exp_icon_2 -%}
                          {%- endif -%}
                        </div>
                        <div class="steam-member-premium__exp-text">
                          <h4 class="steam-member-premium__exp-title">{{ block.settings.exp_title_2 }}</h4>
                          <p class="steam-member-premium__exp-desc">{{ block.settings.exp_desc_2 }}</p>
                        </div>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.exp_title_3 != blank -%}
                      <div class="steam-member-premium__exp-item">
                        <div class="steam-member-premium__exp-icon-wrap">
                          {%- if block.settings.exp_image_3 != blank -%}
                            <img src="{{ block.settings.exp_image_3 | image_url: width: 60 }}" alt="{{ block.settings.exp_title_3 }}" style="width: 18px; height: 18px; object-fit: contain; filter: brightness(0) saturate(100%) invert(84%) sepia(21%) saturate(1512%) hue-rotate(5deg) brightness(93%) contrast(85%);">
                          {%- else -%}
                            {%- render 'premium-icons', icon_name: block.settings.exp_icon_3 -%}
                          {%- endif -%}
                        </div>
                        <div class="steam-member-premium__exp-text">
                          <h4 class="steam-member-premium__exp-title">{{ block.settings.exp_title_3 }}</h4>
                          <p class="steam-member-premium__exp-desc">{{ block.settings.exp_desc_3 }}</p>
                        </div>
                      </div>
                    {%- endif -%}
                  </div>

                </div>

              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- CTA SECTION -->
  <div class="steam-premium__cta">
    <div class="steam-premium__container">
      <div class="steam-premium__cta-banner">
        <div class="steam-premium__cta-bg">
          <img src="{{ 'lumina-experience-reborn.png' | asset_url }}" 
               alt="Beauty luxury background" 
               loading="lazy"
               class="steam-premium__cta-img"
               onerror="this.src='https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&q=80&w=1200';">
          <div class="steam-premium__cta-overlay"></div>
          
          <!-- CTA SVG gold particles overlay -->
          <div class="steam-premium__cta-particles">
            <svg viewBox="0 0 800 400" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M 0,200 Q 200,100 400,200 T 800,200" fill="none" stroke="rgba(212, 175, 55, 0.4)" stroke-width="1.5" stroke-dasharray="5 5">
                <animate attributeName="stroke-dashoffset" values="0;100" dur="15s" repeatCount="indefinite" />
              </path>
              <path d="M 0,150 Q 300,250 500,150 T 800,250" fill="none" stroke="rgba(212, 175, 55, 0.25)" stroke-width="1" stroke-dasharray="10 5">
                <animate attributeName="stroke-dashoffset" values="100;0" dur="20s" repeatCount="indefinite" />
              </path>
            </svg>
          </div>
        </div>

        <div class="steam-premium__cta-content" data-reveal="fade-up">
          <h2 class="steam-premium__cta-title">Frumusețe susținută de <span class="text-gold">știință</span></h2>
          <p class="steam-premium__cta-desc">
            Întâlnește echipa de experți care redefinește îngrijirea pielii prin tehnologia avansată a nanofibrelor.
          </p>
          <a href="/collections/all" class="steam-premium__cta-btn">
            DESCOPERĂ PRODUSELE NOASTRE
            <span class="btn-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- STYLES -->
<style>
  /* Header customization for this template */
  body:has(#section-{{ section.id }}) .site-header,
  body:has(#section-{{ section.id }}) .site-header .header-bottom,
  body:has(#section-{{ section.id }}) .site-header .header-bottom__right,
  body:has(#section-{{ section.id }}) .site-header .toggle-menu-mobile {
    background: transparent !important;
    background-color: transparent !important;
    border-bottom: none !important;
    transition: background 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), backdrop-filter 0.4s ease, border-color 0.4s ease !important;
  }
  
  body:has(#section-{{ section.id }}) .site-header {
    border-bottom: 1px solid rgba(212, 175, 55, 0.15) !important;
    position: absolute !important;
    width: 100% !important;
    z-index: 1000 !important;
  }
  
  body:has(#section-{{ section.id }}) .site-header.scrolled-custom,
  body:has(#section-{{ section.id }}) .site-header.scrolled-custom .header-bottom {
    background: rgba(0, 0, 0, 0.85) !important;
    background-color: rgba(0, 0, 0, 0.85) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
  }
  
  body:has(#section-{{ section.id }}) .site-header.scrolled-custom {
    border-bottom: 1px solid rgba(212, 175, 55, 0.35) !important;
  }

  body:has(#section-{{ section.id }}) {
    background-color: #000000 !important;
  }

  body:has(#section-{{ section.id }}) .main-content,
  body:has(#section-{{ section.id }}) #MainContent,
  body:has(#section-{{ section.id }}) .page-container {
    background-color: #000000 !important;
  }

  body:has(#section-{{ section.id }}) .breadcrumb {
    display: none !important;
  }

  /* Fonts */
  .steam-premium__hero-title,
  .steam-member-premium__name,
  .steam-premium__cta-title {
    font-family: var(--g-font-1), "Playfair Display", "Cormorant Garamond", Georgia, serif !important;
    font-weight: 400 !important;
  }

  .steam-premium__hero-tag,
  .steam-premium__hero-subtitle,
  .steam-member-premium__role,
  .steam-member-premium__desc,
  .steam-member-premium__exp-title,
  .steam-member-premium__exp-desc,
  .steam-premium__cta-desc,
  .steam-premium__cta-btn {
    font-family: var(--g-font-2), "Inter", "DM Sans", Arial, sans-serif !important;
  }

  /* Container */
  .steam-premium__container {
    max-width: 100% !important;
    padding: 0 30px !important;
    width: 100%;
    box-sizing: border-box;
  }

  /* Global helper classes */
  .text-gold {
    color: #D4AF37 !important;
  }

  /* Section Wrapper */
  .steam-premium__section-wrapper {
    overflow: hidden;
    padding-top: 100px; /* offset absolute header */
  }

  /* Hero Section styling */
  .steam-premium__hero {
    padding: 120px 0 40px !important; /* Pushes content down so tag and title are fully visible below the absolute header with an elegant gap */
    position: relative;
  }

  .steam-premium__hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
  }

  .steam-premium__hero-tag {
    color: #D4AF37;
    font-size: 13px;
    letter-spacing: 4px;
    font-weight: 600;
    display: block;
    margin-bottom: 16px;
  }

  .steam-premium__hero-title {
    font-size: 54px;
    line-height: 1.15;
    color: #ffffff;
    margin-bottom: 24px;
  }

  .steam-premium__hero-subtitle {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    max-width: 580px;
    margin-bottom: 32px;
  }

  .steam-premium__hero-divider {
    height: 1px;
    width: 0;
    background: linear-gradient(90deg, #D4AF37, transparent);
    animation: expandDivider 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: 400ms;
  }

  .steam-premium__hero-visual {
    position: relative;
    height: 300px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-particles-canvas {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  @keyframes expandDivider {
    to { width: 100%; }
  }

  /* Team Section Grid */
  .steam-premium__team-grid-section {
    padding: 40px 0 100px;
  }

  .steam-premium__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  /* Card Design */
  .steam-member-premium__card {
    background-color: #050505;
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 18px;
    padding: 40px;
    box-sizing: border-box;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), 
                border-color 0.4s ease, 
                box-shadow 0.4s ease;
    will-change: transform;
    opacity: 0;
    transform: translateY(60px);
  }

  .steam-member-premium__card.reveal-active {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .steam-member-premium__card:hover {
    transform: translateY(-8px);
    border-color: rgba(212, 175, 55, 0.8);
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.08), 0 5px 15px rgba(0, 0, 0, 0.5);
  }

  .steam-member-premium__card-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 30px;
    height: 100%;
  }

  /* Card Portrait Image */
  .steam-member-premium__portrait {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  .steam-member-premium__image-wrapper {
    position: relative;
    padding-top: 130%; /* 4:5 Aspect Ratio */
    width: 100%;
    height: 0;
    overflow: hidden;
    background-color: #0d0d0d;
  }

  .steam-member-premium__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .steam-member-premium__image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0), rgba(0,0,0,0.5)),
                linear-gradient(to top, rgba(0,0,0,0.7), transparent 60%);
    pointer-events: none;
    transition: opacity 0.6s ease;
  }

  .steam-member-premium__card:hover .steam-member-premium__img {
    transform: scale(1.05);
  }

  .steam-member-premium__card:hover .steam-member-premium__image-overlay {
    box-shadow: inset 0 0 40px rgba(212, 175, 55, 0.25);
  }

  /* Card Info (Right) */
  .steam-member-premium__info {
    display: flex;
    flex-direction: column;
  }

  .steam-member-premium__role {
    color: #D4AF37;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    margin-bottom: 8px;
    display: block;
  }

  .steam-member-premium__name {
    font-size: 26px;
    color: #ffffff;
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .steam-member-premium__desc {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 24px;
  }

  /* Expertise list */
  .steam-member-premium__expertises {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: auto;
  }

  .steam-member-premium__exp-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .steam-member-premium__exp-icon-wrap {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(212, 175, 55, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #D4AF37;
    background-color: rgba(212, 175, 55, 0.03);
    margin-top: 2px;
  }

  .steam-member-premium__exp-text {
    display: flex;
    flex-direction: column;
  }

  .steam-member-premium__exp-title {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 2px 0;
  }

  .steam-member-premium__exp-desc {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    line-height: 1.4;
  }

  /* CTA Section Styling */
  .steam-premium__cta {
    padding: 40px 0 100px;
  }

  .steam-premium__cta-banner {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background-color: #050505;
    border: 1px solid rgba(212, 175, 55, 0.25);
    padding: 100px 60px;
    min-height: 380px;
    display: flex;
    align-items: center;
  }

  .steam-premium__cta-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .steam-premium__cta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.45;
  }

  .steam-premium__cta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 10% 50%, rgba(0,0,0,0.85) 20%, rgba(0,0,0,0.5) 60%, rgba(0,0,0,0.9));
  }

  .steam-premium__cta-particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  .steam-premium__cta-particles svg {
    width: 100%;
    height: 100%;
    opacity: 0.6;
  }

  .steam-premium__cta-content {
    position: relative;
    z-index: 3;
    max-width: 600px;
  }

  .steam-premium__cta-title {
    font-size: 42px;
    color: #ffffff;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .steam-premium__cta-desc {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 32px;
  }

  .steam-premium__cta-btn {
    display: inline-flex;
    align-items: center;
    background-color: #D4AF37;
    color: #000000;
    padding: 16px 36px;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), 
                box-shadow 0.3s ease, 
                background-color 0.3s ease;
    border: none;
    outline: none;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.2);
  }

  .steam-premium__cta-btn:hover {
    transform: scale(1.03);
    background-color: #f7d560;
    color: #000000;
    box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
    text-decoration: none;
  }

  .btn-arrow {
    margin-left: 10px;
    display: flex;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .steam-premium__cta-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* Entrance Animation for Hero */
  [data-reveal="fade-up"] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  [data-reveal="fade-up"].reveal-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive styling */
  @media (max-width: 1199px) {
    .steam-premium__grid {
      grid-template-columns: 1fr;
      max-width: 800px;
      margin: 0 auto;
    }
  }

  @media (max-width: 991px) {
    .steam-premium__hero-grid {
      grid-template-columns: 1fr;
      gap: 30px;
      text-align: center;
    }

    .steam-premium__hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .steam-premium__hero-divider {
      margin: 0 auto;
    }

    .steam-premium__hero-visual {
      height: 200px;
    }

    .steam-premium__cta-banner {
      padding: 60px 40px;
      text-align: center;
      justify-content: center;
    }

    .steam-premium__cta-overlay {
      background: rgba(0,0,0,0.85);
    }
  }

  @media (max-width: 767px) {
    .steam-premium__section-wrapper {
      padding-top: 80px;
    }

    .steam-premium__hero {
      padding: 90px 0 20px !important;
    }

    .steam-premium__hero-title {
      font-size: 36px;
    }

    .steam-member-premium__card {
      padding: 24px;
    }

    .steam-member-premium__card-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .steam-member-premium__portrait {
      max-width: 250px;
      margin: 0 auto;
      width: 100%;
    }

    .steam-member-premium__info {
      text-align: center;
    }

    .steam-member-premium__exp-item {
      text-align: left;
    }

    .steam-premium__cta-title {
      font-size: 30px;
    }

