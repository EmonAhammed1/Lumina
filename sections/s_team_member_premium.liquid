<script>
  // 1. Transparent Header on Scroll Handler
  (function() {
    function initHeaderScroll() {
      const header = document.querySelector('.site-header');
      if (header) {
        function handleScroll() {
          if (window.scrollY > 40) {
            header.classList.add('scrolled-custom');
          } else {
            header.classList.remove('scrolled-custom');
          }
        }
        window.addEventListener('scroll', handleScroll, { passive: true });
        handleScroll(); // run once on load
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderScroll);
    } else {
      initHeaderScroll();
    }
  })();

  // 2. Scroll Reveal Animations via Intersection Observer
  (function() {
    function initScrollReveal() {
      const reveals = document.querySelectorAll('[data-reveal], .reveal-card');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('reveal-active');
            observer.unobserve(entry.target); // Trigger only once
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px'
      });
      
      reveals.forEach((el, index) => {
        // Add tiny transition delays for staggering cards in grid
        if (el.classList.contains('steam-member-premium__card')) {
          const isDesktop = window.innerWidth >= 1200;
          if (isDesktop) {
            // alternate stagger for 2 columns
            el.style.transitionDelay = `${(index % 2) * 150}ms`;
          }
        }
        observer.observe(el);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollReveal);
    } else {
      initScrollReveal();
    }
  })();

  // 3. Canvas Gold Particle Wave Animation (Hero Section)
  (function() {
    function initHeroParticles() {
      const canvas = document.getElementById('hero-particles-canvas');
      if (!canvas) return;

      // Disable canvas particles on heavy/low-end mobile devices to conserve memory/power
      if (window.innerWidth < 768) {
        canvas.style.display = 'none';
        return;
      }

      const ctx = canvas.getContext('2d');
      let animationFrameId;

      let width = canvas.width = canvas.parentElement.offsetWidth;
      let height = canvas.height = canvas.parentElement.offsetHeight;

      window.addEventListener('resize', () => {
        if (!canvas || !canvas.parentElement) return;
        width = canvas.width = canvas.parentElement.offsetWidth;
        height = canvas.height = canvas.parentElement.offsetHeight;
      });

      const particles = [];
      const particleCount = 60;
      const goldPalette = ['rgba(212, 175, 55, 0.4)', 'rgba(247, 213, 96, 0.25)', 'rgba(184, 150, 62, 0.35)', 'rgba(255, 255, 255, 0.2)'];

      class Particle {
        constructor() {
          this.reset();
        }

        reset() {
          this.x = Math.random() * width;
          this.y = Math.random() * height;
          this.size = Math.random() * 2 + 0.8;
          this.speedY = -(Math.random() * 0.4 + 0.1);
          this.speedX = Math.random() * 0.3 - 0.15;
          this.color = goldPalette[Math.floor(Math.random() * goldPalette.length)];
          this.opacity = Math.random() * 0.6 + 0.2;
          this.angle = Math.random() * Math.PI * 2;
          this.waveSpeed = Math.random() * 0.02 + 0.005;
          this.waveRadius = Math.random() * 15 + 5;
        }

        update() {
          this.y += this.speedY;
          this.angle += this.waveSpeed;
          this.x += this.speedX + Math.sin(this.angle) * 0.15;

          // Fade out near top
          if (this.y < 20) {
            this.opacity -= 0.01;
          }

          if (this.y < 0 || this.x < 0 || this.x > width || this.opacity <= 0) {
            this.reset();
            this.y = height + 10;
          }
        }

        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = this.color;
          ctx.shadowBlur = this.size * 3;
          ctx.shadowColor = '#D4AF37';
          ctx.fill();
          ctx.shadowColor = 'transparent';
          ctx.shadowBlur = 0;
        }
      }

      for (let i = 0; i < particleCount; i++) {
        particles.push(new Particle());
      }

      // Draw particle waves
      function animate() {
        ctx.clearRect(0, 0, width, height);

        // Draw glowing golden wave background
        const time = Date.now() * 0.001;
        ctx.beginPath();
        ctx.moveTo(0, height * 0.6);
        for (let x = 0; x < width; x++) {
          const y = height * 0.6 + Math.sin(x * 0.004 + time * 0.8) * 20 + Math.cos(x * 0.008 + time * 0.4) * 10;
          ctx.lineTo(x, y);
        }
        ctx.lineTo(width, height);
        ctx.lineTo(0, height);
        ctx.closePath();
        
        const gradient = ctx.createLinearGradient(0, height * 0.5, 0, height);
        gradient.addColorStop(0, 'rgba(212, 175, 55, 0.04)');
        gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
        ctx.fillStyle = gradient;
        ctx.fill();

        // Draw decorative sinus lines
        ctx.beginPath();
        for (let x = 0; x < width; x++) {
          const y = height * 0.55 + Math.sin(x * 0.005 + time) * 15;
          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = 'rgba(212, 175, 55, 0.15)';
        ctx.lineWidth = 1.5;
        ctx.stroke();

        ctx.beginPath();
        for (let x = 0; x < width; x++) {
          const y = height * 0.58 + Math.cos(x * 0.003 + time * 0.7) * 20;
          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = 'rgba(212, 175, 55, 0.08)';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Update and draw particles
        particles.forEach(p => {
          p.update();
          p.draw();
        });

        animationFrameId = requestAnimationFrame(animate);
      }

      animate();

      // Clean up animation if element gets removed/re-rendered in Shopify admin editor
      document.addEventListener('shopify:section:unload', function(e) {
        if (e.detail.sectionId === '{{ section.id }}') {
          cancelAnimationFrame(animationFrameId);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroParticles);
    } else {
      initHeroParticles();
    }
  })();
</script>

