<!-- sections/contact-info-glow.liquid -->

{%- render 'style-section' -%}

<style>
  .cig-section-{{ section.id }} {
    background-color: {{ section.settings.bgsection }};
    color: {{ section.settings.text_color }};
  }
  .cig-container-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }
  .cig-box-{{ section.id }} {
    background-color: {{ section.settings.box_bg }};
    border: 1px solid {{ section.settings.box_border }};
    border-radius: 16px;
    padding: 40px 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4), 
                inset 0 0 15px rgba(229, 184, 105, 0.03), 
                0 0 20px rgba(229, 184, 105, 0.03);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .cig-box-{{ section.id }}:hover {
    border-color: rgba(229, 184, 105, 0.45);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 
                inset 0 0 20px rgba(229, 184, 105, 0.08), 
                0 0 30px rgba(229, 184, 105, 0.08);
  }
  .cig-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
    justify-content: center;
  }
  .cig-icon-container-{{ section.id }} {
    position: relative;
    width: 68px;
    height: 68px;
    border: 1px solid rgba(229, 184, 105, 0.35);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle, rgba(229, 184, 105, 0.12) 0%, transparent 70%);
    box-shadow: 0 0 10px rgba(229, 184, 105, 0.05);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), 
                border-color 0.3s ease, 
                box-shadow 0.3s ease;
    flex-shrink: 0;
  }
  .cig-item-{{ section.id }}:hover .cig-icon-container-{{ section.id }} {
    transform: scale(1.08);
    border-color: {{ section.settings.heading_color }};
    box-shadow: 0 0 20px rgba(229, 184, 105, 0.25);
  }
  .cig-icon-{{ section.id }} {
    width: 22px;
    height: 22px;
    color: {{ section.settings.heading_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cig-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2px;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .cig-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .cig-title-{{ section.id }} {
    font-family: var(--font-heading-family, "Playfair Display", Georgia, serif);
    font-size: 20px;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    margin: 0 0 4px 0;
    letter-spacing: 0.3px;
  }
  .cig-value-{{ section.id }} {
    font-family: var(--font-body-family, "Inter", sans-serif);
    font-size: 15px;
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    opacity: 0.85;
    margin: 0;
  }
  .cig-value-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .cig-value-{{ section.id }} a:hover {
    color: {{ section.settings.heading_color }};
    text-decoration: none;
  }
  .cig-divider-{{ section.id }} {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(229, 184, 105, 0.3), transparent);
    position: relative;
    margin: 0 20px;
    flex-shrink: 0;
  }
  .cig-divider-{{ section.id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 4px;
    height: 4px;
    background-color: {{ section.settings.heading_color }};
    border-radius: 50%;
    box-shadow: 0 0 8px 2px {{ section.settings.heading_color }};
  }

  @media (max-width: 991px) {
    .cig-box-{{ section.id }} {
      flex-direction: column;
      align-items: center;
      padding: 40px 30px;
    }
    .cig-item-{{ section.id }} {
      width: 100%;
      max-width: 290px;
      justify-content: flex-start;
      margin: 0 auto;
      padding: 10px 0;
    }
    .cig-divider-{{ section.id }} {
      width: 80%;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(229, 184, 105, 0.25), transparent);
      margin: 15px auto;
    }
  }
</style>

<div class="customstyle{{ section.id }} cig-section-{{ section.id }}">
  <div class="cig-container-{{ section.id }}" data-aos="fade-up">
    <div class="cig-box-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if forloop.index0 > 0 -%}
          <div class="cig-divider-{{ section.id }}"></div>
        {%- endif -%}
        
        <div class="cig-item-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="cig-icon-container-{{ section.id }}">
            <div class="cig-icon-{{ section.id }}">
              {%- case block.settings.icon -%}
                {%- when 'phone' -%}
                  <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                {%- when 'clock' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {%- when 'mail' -%}
                  <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {%- endcase -%}
            </div>
          </div>
          
          <div class="cig-content-{{ section.id }}">
            {%- if block.settings.title != blank -%}
              <h4 class="cig-title-{{ section.id }}">{{ block.settings.title }}</h4>
            {%- endif -%}
            
            {%- if block.settings.value != blank -%}
              <div class="cig-value-{{ section.id }}">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">{{ block.settings.value }}</a>
                {%- else -%}
                  {{ block.settings.value }}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Info Glow",
  "class": "index-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section",
      "default": "#050505"
    },
    {
      "type": "color",
      "id": "box_bg",
      "label": "Box Background Color",
      "default": "#0d0d0d"
    },
    {
      "type": "color",
      "id": "box_border",
      "label": "Box Border Color",
      "default": "rgba(229, 184, 105, 0.2)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#e5b869"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Padding Section",
      "default": "50px 0px 50px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Section Mobile",
      "default": "30px 0px 30px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginsection",
      "label": "Margin Section",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginmobile",
      "label": "Margin Mobile",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Item Title"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "Item Details"
        },
        {
          "type": "text",
          "id": "link",
          "label": "Optional Link",
          "info": "e.g., tel:+123456 or mailto:hello@brand.com"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "phone", "label": "Phone" },
            { "value": "clock", "label": "Clock" },
            { "value": "mail", "label": "Envelope" }
          ],
          "default": "phone"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Info Glow",
      "blocks": [
        {
          "type": "info_item",
          "settings": {
            "title": "Call us",
            "value": "+41 44 123 4567",
            "link": "tel:+41441234567",
            "icon": "phone"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "title": "Open",
            "value": "Lun-Vin: 9:00 – 18:00",
            "icon": "clock"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "title": "E-mailuri",
            "value": "hello@rmgbrand.com",
            "link": "mailto:hello@rmgbrand.com",
            "icon": "mail"
          }
        }
      ]
    }
  ]
}
{% endschema %}
