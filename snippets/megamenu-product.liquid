{%- liquid
  assign link_column = ''
  assign menu_width = block.settings.menu_width
  assign menu_column = block.settings.menu_column
  assign enable_menu_product = block.settings.enable_menu_product
  assign menu_product_width = block.settings.menu_product_width

  case menu_column
    when 1
    assign link_column = 'col-sm-12'
    when 2
    assign link_column = 'col-sm-6'
    when 3
    assign link_column = 'col-sm-4'
    when 4
    assign link_column = 'col-sm-3'
    when 5
    assign link_column = 'col-1-5'
    when 6
    assign link_column = 'col-sm-2'
    else 
    assign link_column = 'col-sm-2'
  endcase
  -%}
<div class="{{ menu_width }}">
  <div class="row">
    {%- if link.links != blank -%}
    <div class="mega-col mega-link {% if enable_menu_product == false %} col-12 {% else %} col {% endif %}">
      <div class="row">
        {%- if link.links != blank -%}
        {%- for childlink in link.links -%}
        <div class="{{ link_column }} d-col-link">
          <div class="mega-col-inner ">
            <div class="menu-title">
              <a href="{{ childlink.url }}" >
                {%- render 'processMenuTitle' , itemName: childlink.title -%}
                {%- render 'processMenuLabel' , itemName: childlink.title -%}
              </a>
            </div>
            <div class="widget-inner">
              <ul class="nav-links">
                {%- if childlink.links != blank -%}
                {%- for grandchildlink in childlink.links -%}
                <li>
                  <a href="{{ grandchildlink.url }}" >
                    {%- render 'processMenuTitle' , itemName: grandchildlink.title -%}
                    {%- render 'processMenuLabel' , itemName: grandchildlink.title -%}
                  </a>
                </li>
                {%- endfor -%}
                {%- endif -%}
              </ul>
            </div>
          </div>
        </div>
        {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
    {%- endif -%}

    {% if enable_menu_product %}
      <div class="mega-col col" style="max-width:{{ menu_product_width }}%;flex:0 0 {{ menu_product_width }}%;">    
        <div class="row">
          {% for i in (1..6) %}
              {%- liquid
                assign menu_product_var = 'menu_product_' | append: i 
                assign menu_product = block.settings[menu_product_var]
              -%}
              {% if menu_product != blank %}
                <div class="products_menu col mt-3 d-col-link">
                  <div class="custom-featured-menu-card">
                    {%- assign card_image = menu_product.selected_or_first_available_variant.featured_image | default: menu_product.featured_image -%}
                    {%- if card_image != blank -%}
                      <a href="{{ menu_product.url }}" class="meganav-product-image-wrapper overflow-hidden">
                        <img src="{{ card_image | image_url: width: 360, height: 360, crop: 'center' }}"
                             alt="{{ card_image.alt | escape }}"
                             loading="lazy"
                             width="360"
                             height="360"
                             style="max-width: 100%; height: auto; object-fit: cover;" />
                      </a>
                    {%- endif -%}
                    
                    <!-- Product Title -->
                    <h4 class="custom-menu-product-title" style="font-family: var(--g-font-1); font-size: 16px; margin: 8px 0 4px; font-weight: normal; text-transform: none;">
                      <a href="{{ menu_product.url }}" style="color: var(--color-body-headings); text-decoration: none;">
                        {{ menu_product.title }}
                      </a>
                    </h4>

                    <!-- Key Ingredients -->
                    {%- liquid
                      assign ingredients = ""
                      assign count = 0
                      for tag in menu_product.tags
                        if tag contains 'ingredient:'
                          assign ingredient_name = tag | split: ':' | last | strip
                          if count > 0
                            assign ingredients = ingredients | append: ' · ' | append: ingredient_name
                          else
                            assign ingredients = ingredient_name
                          endif
                          assign count = count | plus: 1
                          if count == 3
                            break
                          endif
                        elsif tag contains 'Ingrediente:' or tag contains 'ingrediente:' or tag contains 'Ingredient:'
                          assign ingredient_name = tag | split: ':' | last | strip
                          if count > 0
                            assign ingredients = ingredients | append: ' · ' | append: ingredient_name
                          else
                            assign ingredients = ingredient_name
                          endif
                          assign count = count | plus: 1
                          if count == 3
                            break
                          endif
                        endif
                      endfor

                      if ingredients == blank
                        assign ingredients = "Acid Hialuronic · Vitamina C · Aloe Vera"
                      endif
                    -%}
                    <div class="custom-menu-product-ingredients" style="font-size: 11px; color: var(--color-sub); letter-spacing: 0.1em; margin-bottom: 12px; text-transform: uppercase; line-height: 1.4;">
                      {{ ingredients }}
                    </div>

                    <!-- Discover Button -->
                    <a href="{{ menu_product.url }}" class="btn custom-menu-discover-btn" style="display: block; width: 100%; padding: 8px 0; text-transform: uppercase; font-size: 11px; letter-spacing: 0.15em; border-radius: 4px; text-decoration: none; text-align: center;">
                      Descopera
                    </a>
                  </div>
                </div>
              {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
