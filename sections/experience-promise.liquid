<!-- sections/experience-promise.liquid -->
{%- liquid
  assign animation = section.settings.animation
  assign setwidth = section.settings.setwidth
  assign bgsection = section.settings.bgsection
  assign card_bg = section.settings.card_bg
  assign border_color = section.settings.border_color
  assign title_color = section.settings.title_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
-%}

{%- render 'style-section' -%}

<style>
  .customstyle{{ section.id }} {
    position: relative;
    overflow: hidden;
  }

  .customstyle{{ section.id }} .promise-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .customstyle{{ section.id }} .section-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .customstyle{{ section.id }} .section-subtitle {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: {{ accent_color }};
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }

  .customstyle{{ section.id }} .section-title {
    font-size: 32px;
    font-weight: 400;
    color: {{ title_color }};
    margin: 0;
    font-family: var(--g-font-2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .customstyle{{ section.id }} .promise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .customstyle{{ section.id }} .promise-card {
    position: relative;
    background: {{ card_bg }};
    border: 1px solid {{ border_color }};
    border-radius: 16px;
    padding: 40px 30px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
    height: 100%;
  }

  .customstyle{{ section.id }} .promise-card:hover {
    transform: translateY(-8px);
    border-color: {{ accent_color }};
    box-shadow: 0 12px 40px rgba(197, 160, 89, 0.15);
  }

  /* Shimmer Sweep Animation */
  .customstyle{{ section.id }} .promise-shimmer {
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.03) 30%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.03) 70%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-25deg);
    pointer-events: none;
  }

  /* Run load shimmer once on render */
  .customstyle{{ section.id }} .promise-shimmer.run-load-shimmer {
    animation: shimmer-sweep 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .customstyle{{ section.id }} .promise-card:hover .promise-shimmer {
    animation: shimmer-sweep 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes shimmer-sweep {
    0% {
      left: -150%;
    }
    100% {
      left: 150%;
    }
  }

  /* Card Elements */
  .customstyle{{ section.id }} .promise-icon-wrap {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .customstyle{{ section.id }} .promise-card:hover .promise-icon-wrap {
    transform: scale(1.1);
  }

  .customstyle{{ section.id }} .promise-icon-svg {
    width: 48px;
    height: 48px;
    stroke-width: 1.2;
    transition: stroke 0.4s ease;
  }

  .customstyle{{ section.id }} .promise-icon-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .customstyle{{ section.id }} .promise-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: {{ title_color }};
    margin-bottom: 12px;
    font-family: var(--g-font-2);
    text-transform: uppercase;
  }

  .customstyle{{ section.id }} .promise-desc {
    font-size: 13px;
    line-height: 1.6;
    color: {{ text_color }};
    margin: 0;
    font-weight: 300;
    max-width: 280px;
  }

  .customstyle{{ section.id }} .promise-link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  /* Responsive adjustments */
  @media (max-width: 991px) {
    .customstyle{{ section.id }} .promise-grid {
      gap: 20px;
    }
    .customstyle{{ section.id }} .promise-card {
      padding: 30px 20px;
    }
  }

  @media (max-width: 767px) {
    .customstyle{{ section.id }} .section-header {
      margin-bottom: 30px;
    }
    .customstyle{{ section.id }} .section-title {
      font-size: 24px;
    }
    .customstyle{{ section.id }} .promise-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      max-width: 450px;
      margin: 0 auto;
    }
    .customstyle{{ section.id }} .promise-card {
      padding: 35px 25px;
    }
    .customstyle{{ section.id }} .promise-card:hover {
      transform: translateY(-4px); /* Smaller movement on mobile to feel stable */
    }
  }
</style>

<div class="customstyle{{ section.id }} experience-promise-section" data-aos="{{ animation }}">
  <div class="{{ setwidth }} promise-container">
    {%- if section.settings.section_title != blank or section.settings.subtitle != blank -%}
      <div class="section-header">
        {%- if section.settings.subtitle != blank -%}
          <span class="section-subtitle">{{ section.settings.subtitle }}</span>
        {%- endif -%}
        {%- if section.settings.section_title != blank -%}
          <h2 class="section-title">{{ section.settings.section_title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="promise-grid">
      {%- for block in section.blocks -%}
        <div class="grid-item" {{ block.shopify_attributes }}>
          <div class="promise-card">
            <div class="promise-shimmer run-load-shimmer"></div>
            
            <div class="promise-icon-wrap">
              {%- if block.settings.custom_image != blank -%}
                <img src="{{ block.settings.custom_image | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}" class="promise-icon-img" loading="lazy">
              {%- elsif block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- else -%}
                {%- case block.settings.icon_type -%}
                  {%- when 'shipping' -%}
                    <svg class="promise-icon-svg" viewBox="0 0 24 24" fill="none" stroke="{{ accent_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                      <line x1="12" y1="22.08" x2="12" y2="12" />
                    </svg>
                  {%- when 'circle' -%}
                    <svg class="promise-icon-svg" viewBox="0 0 24 24" fill="none" stroke="{{ accent_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <circle cx="12" cy="12" r="6" stroke-dasharray="2 2" />
                      <polygon points="12 8 13.5 11.5 17 12 14.5 14.5 15 18 12 16.5 9 18 9.5 14.5 7 12 10.5 11.5" />
                    </svg>
                  {%- when 'payment' -%}
                    <svg class="promise-icon-svg" viewBox="0 0 24 24" fill="none" stroke="{{ accent_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                      <rect x="9" y="11" width="6" height="5" rx="1" />
                      <path d="M10 11V9a2 2 0 1 1 4 0v2" />
                    </svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            
            {%- if block.settings.title != blank -%}
              <h3 class="promise-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.description != blank -%}
              <p class="promise-desc">{{ block.settings.description }}</p>
            {%- endif -%}
            
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="promise-link" aria-label="{{ block.settings.title | escape }}"></a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('[Lumina Promise Section] Initialized section: {{ section.id }}');
    
    // Clean up loading shimmer class after 2 seconds
    setTimeout(function() {
      const shimmers = document.querySelectorAll('.customstyle{{ section.id }} .promise-shimmer');
      shimmers.forEach(function(shimmer) {
        shimmer.classList.remove('run-load-shimmer');
      });
      console.log('[Lumina Promise Section] Shimmer loading animation completed.');
    }, 2000);

    // Click events debugging
    const cards = document.querySelectorAll('.customstyle{{ section.id }} .promise-card');
    cards.forEach(function(card, index) {
      card.addEventListener('click', function() {
        const title = this.querySelector('.promise-title')?.textContent.trim() || 'Card ' + (index + 1);
        console.log('[Lumina Promise Section] Card clicked: ' + title);
      });
    });
  });

  // Support Shopify Theme Editor design mode events
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      console.log('[Lumina Promise Section] Re-loaded in Shopify Theme Editor: {{ section.id }}');
      setTimeout(function() {
        const shimmers = document.querySelectorAll('.customstyle{{ section.id }} .promise-shimmer');
        shimmers.forEach(function(shimmer) {
          shimmer.classList.remove('run-load-shimmer');
        });
      }, 2000);
    }
  });
</script>

