<!-- sections/main-terms.liquid -->
{%- liquid
  assign setwidth = section.settings.setwidth | default: 'container'
  assign gold_color = section.settings.gold_color | default: '#c5a059'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign desc_color = section.settings.desc_color | default: '#cccccc'
  assign card_bg = section.settings.card_bg | default: '#0d0d0f'
  assign border_color = section.settings.border_color | default: 'rgba(197, 160, 89, 0.15)'

  assign header_image_url = 'trans-alchemy.jpg' | asset_url
  if section.settings.header_image != blank
    assign header_image_url = section.settings.header_image | image_url: width: 2000
  endif

  assign questions_image_url = 'trans-bottle.jpg' | asset_url
  if section.settings.questions_image != blank
    assign questions_image_url = section.settings.questions_image | image_url: width: 1400
  endif
-%}

{%- render 'style-section' -%}

<style>
  /* Custom Terms Section Base */
  .terms-section-{{ section.id }} {
    background-color: #000000;
    color: {{ text_color }};
    padding-top: 60px;
    padding-bottom: 80px;
  }

  /* Centered Layout Container */
  .terms-container-{{ section.id }} {
    margin-left: auto;
    margin-right: auto;
    padding-left: 15px;
    padding-right: 15px;
    width: 100%;
  }

  /* Header Banner */
  .terms-header-banner-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 380px;
    background-image: url("{{ header_image_url }}");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-bottom: 60px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid {{ border_color }};
  }

  .terms-header-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    padding: 20px;
    max-width: 800px;
  }

  .terms-header-subtitle-{{ section.id }} {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: {{ gold_color }};
    text-transform: uppercase;
    margin-bottom: 15px;
    display: block;
  }

  .terms-header-title-{{ section.id }} {
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    font-size: 52px;
    font-weight: 400;
    color: {{ gold_color }};
    margin: 0 0 20px 0;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  /* Sparkle Separator */
  .terms-sep-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    max-width: 320px;
    margin: 0 auto 25px auto;
  }

  .terms-sep-line-{{ section.id }} {
    flex: 1;
    height: 1px;
    background-color: rgba(197, 160, 89, 0.3);
  }

  .terms-sep-sparkle-{{ section.id }} {
    width: 14px;
    height: 14px;
    color: {{ gold_color }};
    animation: pulse-glow 3s infinite ease-in-out;
  }

  @keyframes pulse-glow {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.2); opacity: 1; filter: drop-shadow(0 0 4px {{ gold_color }}); }
  }

  .terms-header-desc-{{ section.id }} {
    font-size: 16px;
    line-height: 1.6;
    color: {{ desc_color }};
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }

  /* 2-Column Grid Layout */
  .terms-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Sticky Sidebar */
  .terms-sidebar-{{ section.id }} {
    position: -webkit-sticky;
    position: sticky;
    top: 100px;
    background-color: {{ card_bg }};
    border: 1px solid {{ border_color }};
    border-radius: 16px;
    padding: 24px 0;
    box-shadow: 0 15px 30px rgba(0,0,0,0.4);
    z-index: 10;
  }

  .terms-sidebar-nav-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .terms-sidebar-item-{{ section.id }} {
    padding: 0;
    margin: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  }

  .terms-sidebar-item-{{ section.id }}:last-child {
    border-bottom: none;
  }

  .terms-sidebar-link-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 14px 24px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-left: 3px solid transparent;
    cursor: pointer;
  }

  .terms-sidebar-link-{{ section.id }} span.link-num {
    font-family: var(--g-font-1), sans-serif;
    color: {{ gold_color }};
    font-weight: 700;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .terms-sidebar-link-{{ section.id }}:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.02);
    padding-left: 28px;
  }

  .terms-sidebar-link-{{ section.id }}.active {
    color: {{ gold_color }};
    background-color: rgba(197, 160, 89, 0.05);
    border-left-color: {{ gold_color }};
    font-weight: 600;
    padding-left: 28px;
  }

  .terms-sidebar-link-{{ section.id }}.active span.link-num {
    opacity: 1;
  }

  /* Details Panel */
  .terms-content-panel-{{ section.id }} {
    background-color: {{ card_bg }};
    border: 1px solid {{ border_color }};
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 15px 30px rgba(0,0,0,0.4);
    position: relative;
    overflow: hidden;
  }

  /* Shimmer Sweep Hover Effect */
  .terms-content-shimmer-{{ section.id }} {
    position: absolute;
    top: 0;
    left: -150%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.01) 30%,
      rgba(197, 160, 89, 0.06) 50%,
      rgba(255, 255, 255, 0.01) 70%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-25deg);
    pointer-events: none;
    z-index: 1;
  }

  .terms-content-panel-{{ section.id }}:hover .terms-content-shimmer-{{ section.id }} {
    animation: shimmer-sweep 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes shimmer-sweep {
    0% { left: -150%; }
    100% { left: 150%; }
  }

  /* Term Article / Section inside Panel */
  .term-block-{{ section.id }} {
    display: flex;
    gap: 30px;
    align-items: flex-start;
    padding: 35px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.3s ease;
    position: relative;
    z-index: 2;
    scroll-margin-top: 120px;
  }

  .term-block-{{ section.id }}:first-child {
    padding-top: 0;
  }

  .term-block-{{ section.id }}:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* Icon Wrap */
  .term-icon-wrap-{{ section.id }} {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1.5px solid rgba(197, 160, 89, 0.25);
    background-color: rgba(197, 160, 89, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ gold_color }};
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .term-block-{{ section.id }}:hover .term-icon-wrap-{{ section.id }} {
    border-color: {{ gold_color }};
    background-color: rgba(197, 160, 89, 0.08);
    transform: scale(1.08);
    box-shadow: 0 0 15px rgba(197, 160, 89, 0.15);
  }

  .term-icon-wrap-{{ section.id }} svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
    fill: none;
    transition: transform 0.3s ease;
  }

  .term-block-{{ section.id }}:hover .term-icon-wrap-{{ section.id }} svg {
    transform: rotate(5deg);
  }

  /* Term Text Content */
  .term-text-{{ section.id }} {
    flex: 1;
  }

  .term-title-{{ section.id }} {
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    font-size: 20px;
    font-weight: 500;
    color: {{ gold_color }};
    margin: 0 0 12px 0;
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  .term-desc-{{ section.id }} {
    font-size: 14px;
    line-height: 1.65;
    color: {{ desc_color }};
    margin: 0;
    font-weight: 300;
  }
  
  .term-desc-{{ section.id }} p {
    margin: 0 0 10px 0;
  }
  
  .term-desc-{{ section.id }} p:last-child {
    margin-bottom: 0;
  }

  /* Collapsible Extra Content Container */
  .terms-extra-wrap-{{ section.id }} {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.8s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.6s ease;
  }

  .terms-extra-wrap-{{ section.id }}.expanded {
    max-height: 4000px;
    opacity: 1;
  }

  .terms-extra-divider-{{ section.id }} {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: 35px 0 0 0;
    height: 0;
  }

  /* View All Button */
  .terms-btn-container-{{ section.id }} {
    text-align: center;
    margin-top: 40px;
    position: relative;
    z-index: 5;
  }

  .terms-expand-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: transparent;
    color: {{ gold_color }};
    border: 1px solid {{ gold_color }};
    padding: 12px 35px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    outline: none;
  }

  .terms-expand-btn-{{ section.id }} svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    transition: transform 0.4s ease;
  }

  .terms-expand-btn-{{ section.id }}:hover {
    background-color: {{ gold_color }};
    color: #000000;
    box-shadow: 0 8px 25px rgba(197, 160, 89, 0.25);
  }

  .terms-expand-btn-{{ section.id }}:hover svg {
    transform: translateX(4px);
  }

  .terms-expand-btn-{{ section.id }}.expanded svg {
    transform: rotate(90deg);
  }

  .terms-expand-btn-{{ section.id }}.expanded:hover svg {
    transform: rotate(90deg) translateY(4px);
  }

  /* Still Have Questions Banner */
  .questions-banner-{{ section.id }} {
    margin-top: 60px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid {{ border_color }};
    background-image: url("{{ questions_image_url }}");
    background-size: cover;
    background-position: left center;
    background-repeat: no-repeat;
    position: relative;
    box-shadow: 0 15px 35px rgba(0,0,0,0.5);
  }

  .questions-overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.85) 45%, rgba(0, 0, 0, 0.95) 100%);
    z-index: 1;
  }

  .questions-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    padding: 60px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .questions-left-{{ section.id }} {
    max-width: 500px;
  }

  .questions-title-{{ section.id }} {
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    font-size: 38px;
    line-height: 1.25;
    color: #ffffff;
    margin: 0 0 15px 0;
    font-weight: 400;
  }

  .questions-title-{{ section.id }} span {
    color: {{ gold_color }};
    display: block;
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 5px;
    font-family: var(--g-font-1), sans-serif;
  }

  .questions-subtitle-{{ section.id }} {
    font-size: 22px;
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    color: {{ desc_color }};
    margin: 0 0 35px 0;
    font-weight: 300;
  }

  .questions-contact-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: {{ gold_color }};
    color: #000000;
    padding: 14px 38px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 4px 15px rgba(197, 160, 89, 0.2);
  }

  .questions-contact-btn-{{ section.id }} svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    transition: transform 0.3s ease;
  }

  .questions-contact-btn-{{ section.id }}:hover {
    background-color: #ffffff;
    color: #000000;
    box-shadow: 0 8px 25px rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
  }

  .questions-contact-btn-{{ section.id }}:hover svg {
    transform: translateX(4px);
  }

  /* Right Side Contact Info */
  .questions-right-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding-left: 20px;
    border-left: 1px solid rgba(197, 160, 89, 0.15);
  }

  .contact-info-row-{{ section.id }} {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .contact-info-icon-{{ section.id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(197, 160, 89, 0.2);
    background-color: rgba(197, 160, 89, 0.03);
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ gold_color }};
    flex-shrink: 0;
  }

  .contact-info-icon-{{ section.id }} svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
  }

  .contact-info-text-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-info-label-{{ section.id }} {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.40);
    text-transform: uppercase;
  }

  .contact-info-val-{{ section.id }} {
    font-size: 15px;
    color: #ffffff;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 0.3s ease;
    word-break: break-all;
  }

  a.contact-info-val-{{ section.id }}:hover {
    color: {{ gold_color }};
  }

  /* Responsive Design Styles */
  @media (max-width: 1199px) {
    .terms-header-banner-{{ section.id }} {
      height: 340px;
    }
    .terms-header-title-{{ section.id }} {
      font-size: 42px;
    }
    .questions-content-{{ section.id }} {
      padding: 40px;
      gap: 30px;
    }
  }

  @media (max-width: 991px) {
    .terms-grid-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .terms-sidebar-{{ section.id }} {
      position: relative;
      top: 0;
      padding: 15px 0;
      width: 100%;
    }

    .terms-sidebar-nav-{{ section.id }} {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .terms-sidebar-item-{{ section.id }} {
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      border-right: none;
      width: 100%;
    }

    .terms-sidebar-item-{{ section.id }}:last-child {
      border-bottom: none;
    }

    .terms-sidebar-link-{{ section.id }} {
      padding: 14px 24px;
      white-space: normal;
      border-left: 3px solid transparent;
      border-bottom: none;
    }

    .terms-sidebar-link-{{ section.id }}.active {
      border-left-color: {{ gold_color }};
      border-bottom-color: transparent;
      padding-left: 28px;
    }

    .questions-content-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 30px;
    }

    .questions-right-{{ section.id }} {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid rgba(197, 160, 89, 0.15);
      padding-top: 30px;
    }
    
    .terms-header-banner-{{ section.id }} {
      height: 280px;
    }
    .terms-header-title-{{ section.id }} {
      font-size: 34px;
    }
  }

  @media (max-width: 767px) {
    .terms-content-panel-{{ section.id }} {
      padding: 25px 20px;
    }
    .term-block-{{ section.id }} {
      flex-direction: column;
      gap: 15px;
      padding: 25px 0;
    }
  }

  @media (max-width: 575px) {
    .terms-section-{{ section.id }} {
      padding-top: 40px;
      padding-bottom: 60px;
    }
    .terms-header-banner-{{ section.id }} {
      height: 200px;
      margin-bottom: 30px;
    }
    .terms-header-title-{{ section.id }} {
      font-size: 26px;
    }
    .terms-header-desc-{{ section.id }} {
      font-size: 13px;
    }
    .term-icon-wrap-{{ section.id }} {
      width: 48px;
      height: 48px;
    }
    .term-icon-wrap-{{ section.id }} svg {
      width: 20px;
      height: 20px;
    }
    .term-title-{{ section.id }} {
      font-size: 18px;
    }
    .term-desc-{{ section.id }} {
      font-size: 13.5px;
    }
    .questions-title-{{ section.id }} {
      font-size: 24px;
    }
    .questions-subtitle-{{ section.id }} {
      font-size: 16px;
      margin-bottom: 20px;
    }
    .questions-content-{{ section.id }} {
      padding: 30px 15px;
      gap: 25px;
    }
    .questions-right-{{ section.id }} {
      gap: 20px;
      padding-top: 20px;
    }
    .contact-info-row-{{ section.id }} {
      gap: 12px;
    }
  }
</style>

<div class="terms-section-{{ section.id }}" data-aos="fade-up">
  <div class="{{ setwidth }} terms-container-{{ section.id }}">
    
    <!-- Legal Banner Header -->
    <div class="terms-header-banner-{{ section.id }}">
      <div class="terms-header-content-{{ section.id }}">
        <span class="terms-header-subtitle-{{ section.id }}">LEGAL INFORMATION</span>
        <h1 class="terms-header-title-{{ section.id }}">Terms & Conditions</h1>
        
        <!-- Divider -->
        <div class="terms-sep-{{ section.id }}">
          <span class="terms-sep-line-{{ section.id }}"></span>
          <svg class="terms-sep-sparkle-{{ section.id }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3 7 7 3-7 3-3 7-3-7-7-3 7-3 3-7z"/>
          </svg>
          <span class="terms-sep-line-{{ section.id }}"></span>
        </div>

        <p class="terms-header-desc-{{ section.id }}">
          Please read these Terms & Conditions carefully before using our website or purchasing our products.
        </p>
      </div>
    </div>

    <!-- 2-Column Grid Layout -->
    <div class="terms-grid-{{ section.id }}">
      
      <!-- Left Column (Sidebar Nav) -->
      <aside class="terms-sidebar-{{ section.id }}">
        <ul class="terms-sidebar-nav-{{ section.id }}">
          {%- for block in section.blocks -%}
            <li class="terms-sidebar-item-{{ section.id }}" {{ block.shopify_attributes }}>
              <a class="terms-sidebar-link-{{ section.id }} {% if forloop.first %}active{% endif %}" data-target="term-{{ block.id }}">
                <span class="link-num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
                {{ block.settings.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </aside>

      <!-- Right Column (Content Details Panel) -->
      <div class="terms-content-panel-{{ section.id }}">
        <div class="terms-content-shimmer-{{ section.id }}"></div>

        <!-- Scrollable content items (1-5 default, 6-11 collapsible) -->
        <div class="terms-scroll-body-{{ section.id }}">
          
          {%- for block in section.blocks -%}
            {%- if forloop.index == 6 -%}
              <!-- Collapsible Extra Terms Area starts at index 6 -->
              <div class="terms-extra-wrap-{{ section.id }}" id="extra-terms-container">
                <div class="terms-extra-divider-{{ section.id }}"></div>
            {%- endif -%}
            
            <article class="term-block-{{ section.id }}" id="term-{{ block.id }}">
              <div class="term-icon-wrap-{{ section.id }}">
                {%- case block.settings.icon -%}
                  {%- when 'document' -%}
                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  {%- when 'jar' -%}
                    <svg viewBox="0 0 24 24"><path d="M6 10a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v10a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V10z"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/><line x1="6" y1="10" x2="18" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 11 11 13 15 9"/></svg>
                  {%- when 'card' -%}
                    <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'return' -%}
                    <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><polyline points="3 3 3 8 8 8"/></svg>
                  {%- when 'copyright' -%}
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M14.83 14.83a4 4 0 1 1 0-5.66"/></svg>
                  {%- when 'warning' -%}
                    <svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  {%- when 'lock' -%}
                    <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  {%- when 'law' -%}
                    <svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="20"/><line x1="5" y1="9" x2="19" y2="9"/><line x1="5" y1="15" x2="19" y2="15"/></svg>
                  {%- when 'contact' -%}
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {%- endcase -%}
              </div>
              <div class="term-text-{{ section.id }}">
                <h2 class="term-title-{{ section.id }}">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}. {{ block.settings.title }}</h2>
                <div class="term-desc-{{ section.id }}">
                  {{ block.settings.content }}
                </div>
              </div>
            </article>

            {%- if forloop.last and forloop.index >= 6 -%}
              </div> <!-- Close collapsible extra wrapper -->
            {%- endif -%}
          {%- endfor -%}

        </div>

        {%- if section.blocks.size > 5 -%}
          <!-- Button to expand terms (only shown if there are more than 5 terms) -->
          <div class="terms-btn-container-{{ section.id }}">
            <button class="terms-expand-btn-{{ section.id }}" id="terms-toggle-btn">
              <span id="terms-btn-label">View All Terms</span>
              <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        {%- endif -%}

      </div>

    </div>

    <!-- Questions Banner -->
    <div class="questions-banner-{{ section.id }}">
      <div class="questions-overlay-{{ section.id }}"></div>
      <div class="questions-content-{{ section.id }}">
        
        <div class="questions-left-{{ section.id }}">
          <h2 class="questions-title-{{ section.id }}">
            <span>Still have questions?</span>
            Our team is here to assist you.
          </h2>
          <a href="/pages/contact" class="questions-contact-btn-{{ section.id }}">
            Contact Us
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>

        <div class="questions-right-{{ section.id }}">
          
          <!-- Email row -->
          <div class="contact-info-row-{{ section.id }}">
            <div class="contact-info-icon-{{ section.id }}">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-info-text-{{ section.id }}">
              <span class="contact-info-label-{{ section.id }}">Email Us</span>
              <a href="mailto:info@luminaeuropa.eu" class="contact-info-val-{{ section.id }}">info@luminaeuropa.eu</a>
            </div>
          </div>

          <!-- Call row -->
          <div class="contact-info-row-{{ section.id }}">
            <div class="contact-info-icon-{{ section.id }}">
              <svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
            </div>
            <div class="contact-info-text-{{ section.id }}">
              <span class="contact-info-label-{{ section.id }}">Call Us</span>
              <a href="tel:+40123456789" class="contact-info-val-{{ section.id }}">+40 123 456 789</a>
            </div>
          </div>

          <!-- Working Hours row -->
          <div class="contact-info-row-{{ section.id }}">
            <div class="contact-info-icon-{{ section.id }}">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="contact-info-text-{{ section.id }}">
              <span class="contact-info-label-{{ section.id }}">Working Hours</span>
              <span class="contact-info-val-{{ section.id }}">Mon – Fri: 9AM – 6PM (CET)</span>
            </div>
          </div>

        </div>

      </div>
    </div>

  </div>
</div>

<script>
  (function() {
    function initTermsInteractivity() {
      const toggleBtn = document.getElementById('terms-toggle-btn');
      const extraWrap = document.getElementById('extra-terms-container');
      const btnLabel = document.getElementById('terms-btn-label');
      
      // Sidebar link click handling
      const sidebarLinks = document.querySelectorAll('.terms-sidebar-link-{{ section.id }}');
      
      // Expand / Collapse Content
      if (toggleBtn && extraWrap) {
        toggleBtn.addEventListener('click', function() {
          const isExpanded = extraWrap.classList.contains('expanded');
          if (isExpanded) {
            extraWrap.classList.remove('expanded');
            toggleBtn.classList.remove('expanded');
            if (btnLabel) btnLabel.textContent = 'View All Terms';
            
            // Smooth scroll back to section 5 if collapsing and scrolled deep
            const item5 = document.querySelector('.term-block-{{ section.id }}:nth-of-type(5)');
            if (item5) {
              item5.scrollIntoView({ behavior: 'smooth' });
            }
            console.log('[Lumina Terms] Collapsed terms section');
          } else {
            extraWrap.classList.add('expanded');
            toggleBtn.classList.add('expanded');
            if (btnLabel) btnLabel.textContent = 'Collapse Terms';
            console.log('[Lumina Terms] Expanded all terms');
          }
        });
      }

      sidebarLinks.forEach((link, idx) => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const targetId = this.getAttribute('data-target');
          const targetEl = document.getElementById(targetId);
          
          if (!targetEl) return;

          // Check if target is inside the collapsible container (idx >= 5 since 0-indexed)
          if (idx >= 5 && extraWrap && !extraWrap.classList.contains('expanded')) {
            // Expand first, then scroll
            extraWrap.classList.add('expanded');
            if (toggleBtn) toggleBtn.classList.add('expanded');
            if (btnLabel) btnLabel.textContent = 'Collapse Terms';
            
            // Allow small delay for expansion animation to begin so layout math is correct
            setTimeout(() => {
              targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
          } else {
            targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          // Active link tracking
          sidebarLinks.forEach(l => l.classList.remove('active'));
          this.classList.add('active');
          console.log('[Lumina Terms] Navigated to: ' + targetId);
        });
      });

      // Scrollspy logic to automatically highlight active sidebar item on scroll
      const termBlocks = document.querySelectorAll('.term-block-{{ section.id }}');
      const observerOptions = {
        root: null,
        rootMargin: '-20% 0px -60% 0px', // Trigger when block is in center third of screen
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            const correspondingLink = document.querySelector(`.terms-sidebar-link-{{ section.id }}[data-target="${id}"]`);
            if (correspondingLink) {
              sidebarLinks.forEach(l => l.classList.remove('active'));
              correspondingLink.classList.add('active');
              
              // Mobile horizontal scrollspy scroll adjustment removed as list is now vertical
            }
          }
        });
      }, observerOptions);

      termBlocks.forEach(block => observer.observe(block));
      console.log('[Lumina Terms] Interactivity initialized successfully.');
    }

    document.addEventListener('DOMContentLoaded', initTermsInteractivity);
    
    // Shopify Theme Editor compatibility
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        initTermsInteractivity();
      }
    });
  })();
</script>

