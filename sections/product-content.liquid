<!-- product-content.liquid -->
{%- liquid
    assign validRelated = 'col-12'
    assign left_size = 'col-md-6 col-12'
    assign right_size = 'col-md-6 col-12'
    assign setwidth = section.settings.setwidth

    case section.settings.tab_size 
    when 'normal' 
        assign left_size = 'col-md-6 col-12'
        assign right_size = 'col-md-6 col-12'
    when 'large' 
        assign left_size = 'col-md-7 col-12'
        assign right_size = 'col-md-5 col-12'
      when 'largest' 
        assign left_size = 'col-md-8 col-12'
        assign right_size = 'col-md-4 col-12'  
    when 'full' 
        assign left_size = 'col-12'
        assign right_size = 'col-12'  
    endcase

    for block in section.blocks
        if block.type == 'related-product'
            assign validRelated = left_size
        else
            assign validRelated = left_size
        endif
    endfor
-%}
<style>
  @media (min-width:768px){
    .product-related.product-block{
        padding: 0rem 0rem 0rem 2rem;
    }
    .product-content #nav-tab-info .nav-tabs .nav-item{
        margin: 0;
    }
  }
  
  /* Custom Redesigned Tabs Bar */
  .product-content #nav-tab-info .nav-tabs {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    border: 1px solid rgba(197, 160, 89, 0.25);
    background-color: #050505;
    padding: 0;
    margin-bottom: 40px;
    border-radius: 4px;
  }
  .product-content #nav-tab-info .nav-tabs::-webkit-scrollbar {
    display: none;
  }
  .product-content #nav-tab-info .nav-tabs .nav-link {
    color: rgba(255, 255, 255, 0.6) !important;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 18px 26px;
    border: none;
    border-right: 1px solid rgba(197, 160, 89, 0.25) !important;
    margin: 0;
    border-radius: 0;
    position: relative;
    text-transform: uppercase;
    transition: color 0.3s ease;
    background: transparent;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .product-content #nav-tab-info .nav-tabs .nav-link:hover {
    color: #ffffff !important;
  }
  .product-content #nav-tab-info .nav-tabs .nav-link.active {
    color: #c5a059 !important;
    background: transparent;
  }
  .product-content #nav-tab-info .nav-tabs .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20px;
    right: 20px;
    height: 2px;
    background-color: transparent;
    transition: background-color 0.3s ease;
  }
  .product-content #nav-tab-info .nav-tabs .nav-link.active::after {
    background-color: #c5a059;
  }
  
  /* Right social content in tabs bar */
  .tab-bar-right-content {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 10px 20px;
    margin-left: auto;
  }
  .tab-bar-right-text {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    max-width: 250px;
    text-align: right;
    line-height: 1.3;
    font-weight: 300;
  }
  .tab-bar-right-images {
    display: flex;
    gap: 6px;
  }
  .social-img-thumb {
    width: 38px;
    height: 38px;
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid rgba(197, 160, 89, 0.15);
  }
  .social-img-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  /* Special Description Layout Styles */
  .special-desc-container {
    color: #ffffff;
    padding-top: 20px;
    padding-bottom: 20px;
  }
  .special-desc-col-left {
    padding-right: 30px;
  }
  .special-desc-heading {
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    font-size: 38px;
    font-weight: 400;
    color: #c5a059;
    line-height: 1.3;
    margin-bottom: 15px;
    letter-spacing: 0.02em;
  }
  .special-desc-sep {
    display: flex;
    align-items: center;
    gap: 15px;
    margin: 20px 0;
  }
  .sep-line {
    flex: 1;
    height: 1px;
    background-color: rgba(197, 160, 89, 0.2);
  }
  .sep-diamond {
    width: 14px;
    height: 14px;
    color: #c5a059;
  }
  .special-desc-main-text {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 300;
    margin-bottom: 30px;
  }
  .special-desc-main-text p {
    margin: 0 0 15px 0;
  }
  .special-desc-features {
    display: flex;
    flex-direction: column;
  }
  .special-desc-feat-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(197, 160, 89, 0.15);
  }
  .special-desc-feat-item:last-child {
    border-bottom: none;
  }
  .special-desc-feat-icon {
    width: 20px;
    height: 20px;
    color: #c5a059;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .special-desc-feat-icon svg {
    width: 100%;
    height: 100%;
  }
  .special-desc-feat-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 300;
  }
  
  /* Middle Column - Image */
  .special-desc-img-wrap {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.03);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    margin: 0 auto;
    max-width: 100%;
  }
  .special-desc-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .special-desc-img-wrap:hover img {
    transform: scale(1.03);
  }
  
  /* Right Column - Cards */
  .special-desc-card {
    background-color: #0d0d0f;
    border: 1px solid rgba(197, 160, 89, 0.18);
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  .special-desc-card:last-child {
    margin-bottom: 0;
  }
  .special-desc-card .card-subtitle {
    font-size: 11px;
    font-weight: 700;
    color: #c5a059;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }
  .card-big-digits {
    font-family: var(--g-font-2), "Cormorant Garamond", serif;
    font-size: 60px;
    color: #c5a059;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }
  
  /* Timeline */
  .transformation-timeline {
    position: relative;
    padding-top: 15px;
    margin-top: 15px;
  }
  .timeline-line-bg {
    position: absolute;
    top: 19px;
    left: 15px;
    right: 15px;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.15);
  }
  .timeline-line-active {
    position: absolute;
    top: 0;
    left: 0;
    width: 0%; /* Default starting at node 1 */
    height: 100%;
    background-color: #c5a059;
  }
  .timeline-nodes {
    display: flex;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }
  .timeline-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 30%;
  }
  .timeline-node::before {
    content: '';
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background-color: #0d0d0f;
    border: 2px solid rgba(255, 255, 255, 0.3);
    margin-bottom: 10px;
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .timeline-node.active::before {
    background-color: #c5a059;
    border-color: #c5a059;
    box-shadow: 0 0 6px #c5a059;
  }
  .node-time {
    font-size: 12px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 3px;
  }
  .node-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.2;
    font-weight: 300;
  }
  
  /* Perfect list */
  .perfect-list {
    display: flex;
    flex-direction: column;
  }
  .perfect-item {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    padding: 12px 0;
    border-bottom: 1px solid rgba(197, 160, 89, 0.15);
    font-weight: 300;
  }
  .perfect-item:last-child {
    border-bottom: none;
  }
  
  /* Responsive Adjustments */
  @media (max-width: 991px) {
    .product-content #nav-tab-info .nav-tabs {
      flex-direction: column !important;
      align-items: stretch !important;
      overflow-x: visible !important;
      border: 1px solid rgba(197, 160, 89, 0.25) !important;
      background-color: #050505 !important;
      border-radius: 4px !important;
      margin-bottom: 30px !important;
    }
    .product-content #nav-tab-info .nav-tabs .nav-link {
      width: 100% !important;
      padding: 16px 20px !important;
      border: none !important;
      border-bottom: 1px solid rgba(197, 160, 89, 0.25) !important;
      text-align: left !important;
      border-radius: 0 !important;
      white-space: normal !important;
      flex-shrink: 1 !important;
    }
    .product-content #nav-tab-info .nav-tabs .nav-link:last-child {
      border-bottom: none !important;
    }
    .product-content #nav-tab-info .nav-tabs .nav-link::after {
      display: none !important;
    }
    .product-content #nav-tab-info .nav-tabs .nav-link.active {
      color: #c5a059 !important;
      background-color: rgba(197, 160, 89, 0.04) !important;
    }
    
    .special-desc-col-left {
      padding-right: 15px;
      margin-bottom: 40px;
    }
    .special-desc-col-mid {
      margin-bottom: 40px;
    }
    .special-desc-img-wrap {
      max-width: 450px;
    }
    .card-big-digits {
      font-size: 50px;
    }
  }
</style>

<div class="section-{{ section.id }} product-content customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}" >
  {%- render 'style-section' -%}  
  <div class="{{ setwidth }}">
        <div class="row justify-content-center">
            <div id="nav-tab-info" class="nav-tab-info {{ left_size }}" data-aos="{{ section.settings.animation }}" >
                <div class="nav nav-tabs {% if section.settings.enable_left %} justify-content-start {% endif %}" role="tablist">
                    {%- for block in section.blocks -%}
                        {%- liquid
                            if forloop.first == true
                                assign active = 'active'
                            else
                                assign active = ''
                            endif
                        -%}
                        {%- case block.type -%}
                            {%- when 'description' -%}
                                <a class="nav-item nav-link {{ active }} disabled-anchor" href="#gtab{{ block.id }}" data-toggle="tab" role="tab" aria-selected="true">
                                    {{ block.settings.title_tab | default: 'Description' }}
                                </a>
                            {%- when 'custom_liquid' -%}
                                <a class="nav-item nav-link {{ active }} disabled-anchor" href="#gtab{{ block.id }}" data-toggle="tab" role="tab" aria-selected="true">
                                    {{ block.settings.title_tab | default: 'Custom Liquid' }}
                                </a>
                            {%- when 'content' -%}
                                <a class="nav-item nav-link {{ active }} disabled-anchor" href="#gtab{{ block.id }}" data-toggle="tab" role="tab" aria-selected="true">
                                    {{ block.settings.title_tab | default: 'Title Content' }}
                                </a>
                            {%- when 'review' -%}
                                    <a class="nav-item nav-link {{ active }} disabled-anchor" href="#gtab{{ block.id }}" data-toggle="tab" role="tab" aria-selected="true">
                                        {{ block.settings.title_tab | default: 'Reviews' }}
                                    </a>
                            {%- endcase -%}
                    {%- endfor -%}
                    
                    {%- if section.settings.show_social_right -%}
                      <div class="tab-bar-right-content d-none d-lg-flex">
                        {%- if section.settings.social_right_text != blank -%}
                          <span class="tab-bar-right-text">{{ section.settings.social_right_text }}</span>
                        {%- endif -%}
                        <div class="tab-bar-right-images">
                          {%- if section.settings.social_img_1 != blank -%}
                            <div class="social-img-thumb">
                              <img src="{{ section.settings.social_img_1 | image_url: width: 80 }}" alt="" loading="lazy">
                            </div>
                          {%- endif -%}
                          {%- if section.settings.social_img_2 != blank -%}
                            <div class="social-img-thumb">
                              <img src="{{ section.settings.social_img_2 | image_url: width: 80 }}" alt="" loading="lazy">
                            </div>
                          {%- endif -%}
                          {%- if section.settings.social_img_3 != blank -%}
                            <div class="social-img-thumb">
                              <img src="{{ section.settings.social_img_3 | image_url: width: 80 }}" alt="" loading="lazy">
                            </div>
                          {%- endif -%}
                          {%- if section.settings.social_img_4 != blank -%}
                            <div class="social-img-thumb">
                              <img src="{{ section.settings.social_img_4 | image_url: width: 80 }}" alt="" loading="lazy">
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                </div>
                <div class="tab-content">
                    {%- for block in section.blocks -%}
                        {%- liquid
                            if forloop.first == true
                                assign activetab = 'show active'
                            else
                                assign activetab = ''
                            endif
                        -%}
                        {%- case block.type -%}
                            {%- when 'description' -%}
                                <div class="tab-pane fade {{ activetab }}" id="gtab{{ block.id }}" role="tabpanel" >
                                    {%- if block.settings.enable_special -%}
                                      <div class="special-desc-container">
                                        <div class="row">
                                          
                                          <!-- Left Column: Text & Features -->
                                          <div class="col-12 col-lg-5 col-xl-5 special-desc-col-left">
                                            {%- if block.settings.left_heading != blank -%}
                                              <h2 class="special-desc-heading">{{ block.settings.left_heading }}</h2>
                                            {%- endif -%}
                                            
                                            <div class="special-desc-sep">
                                              <span class="sep-line"></span>
                                              <svg class="sep-diamond" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M12 2l3 7 7 3-7 3-3 7-3-7-7-3 7-3 3-7z"/>
                                              </svg>
                                              <span class="sep-line"></span>
                                            </div>
                                            
                                            {%- if block.settings.left_desc != blank -%}
                                              <div class="special-desc-main-text">
                                                {{ block.settings.left_desc }}
                                              </div>
                                            {%- endif -%}
                                            
                                            <div class="special-desc-features">
                                              {%- for i in (1..4) -%}
                                                {%- liquid
                                                  assign feat_icon_key = 'feat_' | append: i | append: '_icon'
                                                  assign feat_text_key = 'feat_' | append: i | append: '_text'
                                                  assign feat_icon = block.settings[feat_icon_key]
                                                  assign feat_text = block.settings[feat_text_key]
                                                -%}
                                                {%- if feat_text != blank -%}
                                                  <div class="special-desc-feat-item">
                                                    <div class="special-desc-feat-icon">
                                                      {%- case feat_icon -%}
                                                        {%- when 'water' -%}
                                                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                                                        {%- when 'sparkle' -%}
                                                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                                                        {%- when 'wave' -%}
                                                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c3.2-1.5 5.8 1.5 9 0 3.2-1.5 5.8 1.5 9 0M2 12c3.2-1.5 5.8 1.5 9 0 3.2-1.5 5.8 1.5 9 0M2 18c3.2-1.5 5.8 1.5 9 0 3.2-1.5 5.8 1.5 9 0"/></svg>
                                                        {%- when 'leaf' -%}
                                                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22c0-5.5 4.5-10 10-10h10v2C22 19.5 17.5 24 12 24H2z"/><path d="M12 12C6.5 12 2 16.5 2 22"/></svg>
                                                      {%- endcase -%}
                                                    </div>
                                                    <div class="special-desc-feat-text">{{ feat_text }}</div>
                                                  </div>
                                                {%- endif -%}
                                              {%- endfor -%}
                                            </div>
                                          </div>
                                          
                                          <!-- Middle Column: Portrait Image -->
                                          <div class="col-12 col-lg-4 col-xl-4 text-center special-desc-col-mid">
                                            <div class="special-desc-img-wrap">
                                              {%- if block.settings.mid_image != blank -%}
                                                <img src="{{ block.settings.mid_image | image_url: width: 600 }}" alt="" loading="lazy">
                                              {%- else -%}
                                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                                              {%- endif -%}
                                            </div>
                                          </div>
                                          
                                          <!-- Right Column: Timeline & Perfect For Cards -->
                                          <div class="col-12 col-lg-3 col-xl-3 special-desc-col-right">
                                            
                                            <!-- Card 1: Timeline -->
                                            <div class="special-desc-card transformation-card">
                                              {%- if block.settings.card_1_title != blank -%}<span class="card-subtitle">{{ block.settings.card_1_title }}</span>{%- endif -%}
                                              {%- if block.settings.card_1_time != blank -%}<div class="card-big-digits">{{ block.settings.card_1_time }}</div>{%- endif -%}
                                              
                                              <div class="transformation-timeline">
                                                <div class="timeline-line-bg">
                                                  <div class="timeline-line-active"></div>
                                                </div>
                                                <div class="timeline-nodes">
                                                  <div class="timeline-node node-1 active">
                                                    <span class="node-time">{{ block.settings.timeline_val_1 }}</span>
                                                    <span class="node-label">{{ block.settings.timeline_lbl_1 }}</span>
                                                  </div>
                                                  <div class="timeline-node node-2">
                                                    <span class="node-time">{{ block.settings.timeline_val_2 }}</span>
                                                    <span class="node-label">{{ block.settings.timeline_lbl_2 }}</span>
                                                  </div>
                                                  <div class="timeline-node node-3">
                                                    <span class="node-time">{{ block.settings.timeline_val_3 }}</span>
                                                    <span class="node-label">{{ block.settings.timeline_lbl_3 }}</span>
                                                  </div>
                                                </div>
                                              </div>
                                            </div>
                                            
                                            <!-- Card 2: Perfect For -->
                                            <div class="special-desc-card perfect-card">
                                              {%- if block.settings.card_2_title != blank -%}<span class="card-subtitle">{{ block.settings.card_2_title }}</span>{%- endif -%}
                                              <div class="perfect-list">
                                                {%- if block.settings.perfect_1 != blank -%}<div class="perfect-item">{{ block.settings.perfect_1 }}</div>{%- endif -%}
                                                {%- if block.settings.perfect_2 != blank -%}<div class="perfect-item">{{ block.settings.perfect_2 }}</div>{%- endif -%}
                                                {%- if block.settings.perfect_3 != blank -%}<div class="perfect-item">{{ block.settings.perfect_3 }}</div>{%- endif -%}
                                                {%- if block.settings.perfect_4 != blank -%}<div class="perfect-item">{{ block.settings.perfect_4 }}</div>{%- endif -%}
                                              </div>
                                            </div>
                                            
                                          </div>
                                          
                                        </div>
                                      </div>
                                    {%- else -%}
                                      {{ product.description }}
                                    {%- endif -%}
                                </div>
                            {%- when 'custom_liquid' -%}
                                <div class="tab-pane fade {{ activetab }}" id="gtab{{ block.id }}" role="tabpanel" >
                                    {{ block.settings.custom_liquid }}
                                </div>
                            {%- when 'content' -%}
                                <div class="tab-pane fade {{ activetab }}" id="gtab{{ block.id }}" role="tabpanel" >
                                    {{ block.settings.answer_content }}
                                    {{ block.settings.page.content }}
                                </div>
                            {%- when 'review' -%}
                                <div class="tab-pane fade {{ activetab }}" id="gtab{{ block.id }}" role="tabpanel">
                                    <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
                                </div>
                        {%- endcase -%}
                    {%- endfor -%}
                </div>
            </div>
            
            {%- for block in section.blocks -%}
                {%- if block.type == 'related-product' -%}
                    <div class="{{ right_size }}" data-aos-delay="200" data-aos="{{ section.settings.animation }}" >
                      <div class="product-block product-related mt-lg-0 mt-4 {% if section.settings.tab_size  == 'full' %} pl-0 {% endif %}">
                            <product-pairs class="product-pairs isolate product-pairs--loaded" data-id="{{ section.id }}" 
                              data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_limit }}&intent=complementary">
                              {% if recommendations.performed and recommendations.products_count > 0 %}
                                {%- if block.settings.title_heading != blank -%}
                                  <h5 class="mb-4 {{ block.settings.size_text }}">{{ block.settings.title_heading }}</h5>
                                {%- endif -%}
                                <div class="row">
                                  {% for recommendation in recommendations.products %}
                                    <div class="col-lg col-6">
                                    {%- render 'product-grid-buywith', product: recommendation -%}
                                  </div>
                                  {% endfor %}
                                </div>
                              {% endif %}
                            </product-pairs>
                        </div>
                    </div>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
</div>

{% javascript %}
  class productPairs extends HTMLElement {
    connectedCallback() {
      fetch(this.dataset.url).
      then((response) => {
        if (!response.ok) {
          throw new Error("HTTP error! Status: ".concat(response.status));
        }
        return response.text();
      }).
      then((response) => {
        var frag = document.createDocumentFragment(),
          fetchedContent = document.createElement('div');
        frag.appendChild(fetchedContent);
        fetchedContent.innerHTML = response;

        var replacementContent = fetchedContent.querySelector("[data-id=\"".concat(CSS.escape(this.dataset.id), "\"]"));
        if (replacementContent) {
          this.innerHTML = replacementContent.innerHTML;
        }
      });
    }
  }

  customElements.define('product-pairs', productPairs);
{% endjavascript %}
{% schema %}
{
  "name": "Product Content",
  "tag": "section",
  "class": "section",
