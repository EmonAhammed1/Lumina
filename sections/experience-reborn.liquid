<!-- sections/experience-reborn.liquid -->
{%- liquid
  assign animation = section.settings.animation
  assign setwidth = section.settings.setwidth
  assign image_position = section.settings.image_position
  assign image = section.settings.image
  assign min_height_mobile = section.settings.min_height_mobile
  assign image_zoom = section.settings.image_zoom | default: 1.0
  assign image_align_x = section.settings.image_align_x | default: 50
  assign image_align_y = section.settings.image_align_y | default: 50
  assign bg_text_col = section.settings.bg_text_col
  assign subtitle = section.settings.subtitle
  assign heading_1 = section.settings.heading_1
  assign heading_2 = section.settings.heading_2
  assign des = section.settings.des
  
  assign color_subtitle = section.settings.color_subtitle
  assign color_heading_1 = section.settings.color_heading_1
  assign color_heading_2 = section.settings.color_heading_2
  assign color_text = section.settings.color_text
  assign color_line = section.settings.color_line

  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign style_btn = section.settings.style_btn

  if image_position == 'right'
    assign text_col_padding = 'pl-md-0 pr-md-5'
  else
    assign text_col_padding = 'pr-md-0 pl-md-5'
  endif
-%}

{%- render 'style-section' -%}

<style>
  .customstyle{{ section.id }} {
    overflow: hidden;
  }
  .customstyle{{ section.id }} .row-flex {
    display: flex;
    flex-wrap: wrap;
  }
  .customstyle{{ section.id }} .experience-text-col {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ bg_text_col }};
  }
  @media (min-width: 768px) {
    .customstyle{{ section.id }} .experience-text-col {
      justify-content: {% if image_position == 'right' %}flex-start{% else %}flex-end{% endif %};
    }
  }
  .customstyle{{ section.id }} .experience-content-inner {
    width: 100%;
    max-width: 500px;
  }
  .customstyle{{ section.id }} .experience-subtitle-wrap {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
  }
  .customstyle{{ section.id }} .experience-subtitle {
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ color_subtitle }};
    font-weight: 600;
    font-family: var(--g-font-2);
  }
  .customstyle{{ section.id }} .gold-line {
    display: inline-block;
    height: 1px;
    width: 45px;
    background-color: {{ color_line }};
    margin-left: 15px;
  }
  .customstyle{{ section.id }} .experience-heading {
    font-size: calc(var(--g-h2-font-size) + 8px);
    line-height: 1.15;
    color: {{ color_heading_1 }};
    font-weight: 400;
  }
  .customstyle{{ section.id }} .experience-heading .heading-gold {
    color: {{ color_heading_2 }};
  }
  .customstyle{{ section.id }} .gold-divider {
    height: 1px;
    width: 40px;
    background-color: {{ color_line }};
  }
  .customstyle{{ section.id }} .experience-desc {
    color: {{ color_text }};
    font-size: 15px;
    line-height: 1.7;
  }
  .customstyle{{ section.id }} .experience-desc p {
    margin-bottom: 0;
    color: {{ color_text }} !important;
  }
  .customstyle{{ section.id }} .experience-image-col {
    position: relative;
    min-height: {{ min_height_mobile }}px;
    display: flex;
    flex-direction: column;
  }
  .customstyle{{ section.id }} .experience-image-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    flex-grow: 1;
  }
  .customstyle{{ section.id }} .experience-image-container::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    background: linear-gradient(to right, {{ bg_text_col }} 0%, rgba(1, 1, 1, 0) 15%, rgba(1, 1, 1, 0) 80%, {{ bg_text_col }} 100%),
                linear-gradient(to bottom, rgba(1, 1, 1, 0) 80%, {{ bg_text_col }} 100%);
  }
  .customstyle{{ section.id }} .image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .customstyle{{ section.id }} .experience-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: {{ image_align_x }}% {{ image_align_y }}% !important;
    transform: scale({{ image_zoom }}) !important;
    transform-origin: {{ image_align_x }}% {{ image_align_y }}% !important;
    transition: transform 0.8s ease !important;
  }
  .customstyle{{ section.id }}:hover .experience-img {
    transform: scale(calc({{ image_zoom }} + 0.05)) !important;
  }
  @media (min-width: 768px) {
    .customstyle{{ section.id }} .experience-image-col {
      min-height: auto;
      align-self: stretch;
    }
  }
  @media (max-width: 749px) {
    .customstyle{{ section.id }} .experience-heading {
      font-size: calc(var(--g-h2-font-size-mobile) + 4px);
    }
    .customstyle{{ section.id }} .experience-desc {
      font-size: 14px;
    }
    .customstyle{{ section.id }} .gold-line {
      width: 30px;
    }
  }
</style>

<div class="customstyle{{ section.id }} experience-reborn-section" data-aos="{{ animation }}">
  <div class="{{ setwidth }}">
    <div class="section-block p-0">
      <div class="row no-gutters row-flex {% if image_position == 'left' %} flex-row-reverse {% endif %}">
        
        <!-- Text Column -->
        <div class="col-12 col-md-6 py-5 px-4 {{ text_col_padding }} experience-text-col">
          <div class="experience-content-inner py-lg-4" data-aos="{{ animation }}" data-aos-delay="100">
            {%- if subtitle != blank -%}
              <div class="experience-subtitle-wrap">
                <span class="experience-subtitle">{{ subtitle }}</span>
                <span class="gold-line"></span>
              </div>
            {%- endif -%}
            
            {%- if heading_1 != blank or heading_2 != blank -%}
              <h2 class="experience-heading font-family-1 mb-3">
                {%- if heading_1 != blank -%}
                  <span class="heading-white">{{ heading_1 }}</span>
                {%- endif -%}
                {%- if heading_2 != blank -%}
                  <span class="heading-gold font-italic d-block mt-1">{{ heading_2 }}</span>
                {%- endif -%}
              </h2>
            {%- endif -%}
            
            <div class="gold-divider mb-4 mt-3"></div>
            
            {%- if des != blank -%}
              <div class="experience-desc rte mb-2">
                {{ des }}
              </div>
            {%- endif -%}
            
            {%- if button_label != blank and button_link != blank -%}
              <div class="experience-btn-wrap mt-4 pt-2">
                <a href="{{ button_link }}" class="btn {{ style_btn }}">
                  {{ button_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Image Column -->
        <div class="col-12 col-md-6 experience-image-col">
          <div class="experience-image-container" data-aos="{{ animation }}" data-aos-delay="200">
            <div class="image-wrapper">
              {%- if image != blank -%}
                {%- assign img_url = image | image_url: width: 1 | replace: 'width=1', 'width={width}' -%}
                <img class="experience-img lazyload"
                     src="{{ image | image_url: width: 300 }}"
                     data-src="{{ img_url }}"
                     data-widths="[360, 540, 720, 900, 1080, 1296]"
                     data-aspectratio="{{ image.aspect_ratio }}"
                     data-sizes="auto"
                     alt="{{ image.alt | escape }}"
                     loading="lazy"
                     width="{{ image.width }}"
                     height="{{ image.height }}">
              {%- else -%}
                <!-- Fallback to uploaded mask image in assets -->
                <img class="experience-img lazyload"
                     src="{{ 'lumina-experience-reborn.png' | asset_img_url: '300x' }}"
                     data-src="{{ 'lumina-experience-reborn.png' | asset_img_url: 'master' }}"
                     alt="Lumina Europa Experience"
                     loading="lazy">
              {%- endif -%}
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Experience Reborn",
  "class": "index-section-experience",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "options": [
        { "value": "", "label": "None" },
        { "value": "fade", "label": "Fade" },
        { "value": "fade-up", "label": "Fade Up" },
        { "value": "fade-down", "label": "Fade Down" },
        { "value": "fade-left", "label": "Fade Left" },
        { "value": "fade-right", "label": "Fade Right" },
        { "value": "zoom-in", "label": "Zoom In" },
        { "value": "zoom-out", "label": "Zoom Out" }
      ],
      "default": "fade-up",
      "label": "Select Animation"
    },
    {
      "type": "select",
      "id": "setwidth",
      "label": "Full Width Wrapper",
      "default": "container-fluid",
      "options": [
        { "value": "container", "label": "Box" },
        { "value": "container-fluid", "label": "Container Fluid" },
        { "value": "full", "label": "Full" }
      ]
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "default": "right",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 250,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Min Height Image (Mobile)",
      "default": 400
    },
    {
      "type": "range",
      "id": "image_zoom",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "label": "Image Zoom",
      "default": 1.3
    },
    {
      "type": "range",
      "id": "image_align_x",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image Position Horizontal (X)",
      "default": 70
    },
    {
      "type": "range",
      "id": "image_align_y",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image Position Vertical (Y)",
      "default": 50
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_text_col",
      "label": "Background Text Column",
      "default": "#010101"
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section Outer",
      "default": "#010101"
    },
    {
      "type": "color",
      "id": "color_subtitle",
      "label": "Subtitle Color",
      "default": "#b8963e"
    },
    {
      "type": "color",
      "id": "color_heading_1",
      "label": "Heading Part 1 Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_heading_2",
      "label": "Heading Part 2 (Italic) Color",
      "default": "#b8963e"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text Color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "color_line",
      "label": "Line Color",
      "default": "#b8963e"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "EXPERIENȚA LUMINA EUROPA"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading Part 1",
      "default": "Experimentează o Piele"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading Part 2 (Italic)",
      "default": "Care se Simte Renăscută"
    },
    {
      "type": "richtext",
      "id": "des",
      "label": "Description",
      "default": "<p>Alimentat de tehnologia avansată a nanofibrelor, Lumina Europa îți transformă ritualul de îngrijire a pielii într-un moment de reînnoire vizibilă. Experimentează o hidratare profundă, o textură mai fină și o strălucire radiantă menită să-ți lase pielea revigorată, fermă și frumos revitalizată.</p>"
    },
    {
      "type": "header",
      "content": "Button settings"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "style_btn",
      "label": "Style Button",
      "default": "btn-theme",
      "options": [
        { "value": "btn-theme", "label": "Button Box" },
        { "value": "btn-theme btn-white", "label": "Button Box White" },
        { "value": "btn-underline", "label": "Button Line" },
        { "value": "btn-underline btn-underline-white", "label": "Button Line White" },
        { "value": "btn-outline", "label": "Button Outline" },
        { "value": "btn-outline btn-outline-white", "label": "Button Outline White" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding "
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Padding Section",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Section Mobile",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "Section Margin "
    },
    {
      "type": "text",
      "id": "marginsection",
      "label": "Margin Section",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginmobile",
      "label": "Margin Mobile",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    }
  ],
  "presets": [
    {
      "name": "Experience Reborn",
      "category": "Image"
    }
  ]
}
{% endschema %}
